{
    "$schema": "https://json.schemastore.org/tsconfig.json",
    "compilerOptions": {
        "noImplicitThis": true,
        "useUnknownInCatchVariables": true,
        "allowJs": false,
        "lib": ["ES2025"],
        "strict": true,
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "jsxImportSource": "gnim/gtk4",
        "types": ["../.types/gi"]
    }
}
